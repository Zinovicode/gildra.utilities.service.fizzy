#!/bin/bash -e

# If running the rails server then create or migrate existing database
if [ "${1}" == "./bin/thrust" ] && [ "${2}" == "./bin/rails" ] && [ "${3}" == "server" ]; then
  # On Render, we can't drop/create the DB. Just migrate.
  # If tables exist from a partial migration, this will continue from where it left off.
  ./bin/rails db:migrate || true
fi

exec "${@}"
