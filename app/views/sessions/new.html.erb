<% @page_title = "Sign in to Gildra" %>

<style>
  @import url('https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;0,700;1,300&family=Inter:wght@400;500;600&display=swap');

  .gildra-login {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    min-height: 70vh;
    padding: 40px 24px;
  }

  .gildra-logo {
    display: flex;
    align-items: center;
    gap: 14px;
    margin-bottom: 8px;
  }

  .gildra-bars {
    display: flex;
    gap: 5px;
    align-items: center;
  }

  .gildra-bars .bar {
    width: 6px;
    border-radius: 3px;
    background: #14B8A6;
  }

  .gildra-wordmark {
    font-family: 'Cormorant Garamond', serif;
    font-weight: 700;
    font-size: 52px;
    letter-spacing: 10px;
    color: #14B8A6;
    line-height: 1;
  }

  .gildra-tagline {
    font-family: 'Cormorant Garamond', serif;
    font-weight: 300;
    font-style: italic;
    font-size: 14px;
    letter-spacing: 5px;
    color: #a1a1aa;
    text-transform: lowercase;
    margin-bottom: 48px;
  }

  .gildra-card {
    background: #18181b;
    border: 1px solid #27272a;
    border-radius: 16px;
    padding: 40px;
    width: 100%;
    max-width: 400px;
    text-align: center;
  }

  .gildra-card-title {
    font-family: 'Inter', system-ui, sans-serif;
    font-weight: 600;
    font-size: 16px;
    color: #fafafa;
    margin-bottom: 8px;
  }

  .gildra-card-subtitle {
    font-family: 'Inter', system-ui, sans-serif;
    font-size: 13px;
    color: #71717a;
    margin-bottom: 28px;
    line-height: 1.5;
  }

  .gildra-google-btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 10px;
    width: 100%;
    padding: 12px 24px;
    background: #14B8A6;
    color: #09090b;
    border: none;
    border-radius: 10px;
    font-family: 'Inter', system-ui, sans-serif;
    font-size: 14px;
    font-weight: 600;
    letter-spacing: 0.5px;
    cursor: pointer;
    transition: background 0.2s;
  }

  .gildra-google-btn:hover {
    background: #2dd4bf;
  }

  .gildra-footer-text {
    margin-top: 32px;
    font-family: 'Inter', system-ui, sans-serif;
    font-size: 11px;
    color: #3f3f46;
    letter-spacing: 2px;
    text-transform: uppercase;
  }

  @media (max-width: 500px) {
    .gildra-wordmark { font-size: 36px; letter-spacing: 6px; }
    .gildra-card { padding: 28px 20px; }
  }
</style>

<div class="gildra-login">
  <div class="gildra-logo">
    <div class="gildra-bars">
      <div class="bar" style="height: 30px;"></div>
      <div class="bar" style="height: 42px;"></div>
      <div class="bar" style="height: 30px;"></div>
    </div>
    <div class="gildra-wordmark">GILDRA</div>
  </div>
  <div class="gildra-tagline">The beauty app</div>

  <div class="gildra-card">
    <div class="gildra-card-title">Welcome back</div>
    <div class="gildra-card-subtitle">Sign in with your Google account to continue.</div>

    <%= form_with url: "/auth/google_oauth2", method: :post, data: { turbo: false } do %>
      <button type="submit" class="gildra-google-btn">
        <svg width="18" height="18" viewBox="0 0 18 18" xmlns="http://www.w3.org/2000/svg">
          <path d="M17.64 9.2c0-.637-.057-1.251-.164-1.84H9v3.481h4.844a4.14 4.14 0 0 1-1.796 2.716v2.259h2.908c1.702-1.567 2.684-3.875 2.684-6.615z" fill="#4285F4"/>
          <path d="M9 18c2.43 0 4.467-.806 5.956-2.18l-2.908-2.259c-.806.54-1.837.86-3.048.86-2.344 0-4.328-1.584-5.036-3.711H.957v2.332A8.997 8.997 0 0 0 9 18z" fill="#34A853"/>
          <path d="M3.964 10.71A5.41 5.41 0 0 1 3.682 9c0-.593.102-1.17.282-1.71V4.958H.957A8.996 8.996 0 0 0 0 9c0 1.452.348 2.827.957 4.042l3.007-2.332z" fill="#FBBC05"/>
          <path d="M9 3.58c1.321 0 2.508.454 3.44 1.345l2.582-2.58C13.463.891 11.426 0 9 0A8.997 8.997 0 0 0 .957 4.958L3.964 6.29C4.672 4.163 6.656 2.58 9 3.58z" fill="#EA4335"/>
        </svg>
        Sign in with Google
      </button>
    <% end %>
  </div>

  <div class="gildra-footer-text">Gildra Utilities</div>
</div>

<% content_for :header do %>
  <style>.header { display: none; }</style>
<% end %>
